sort=-time
sort=+priority
layer=overlay
background-color=#1e1e2ec0
width=300
height=300
outer-margin=15
margin=6
padding=9,6
border-size=3
text-color=#cdd6f4
border-color=#cdd6f4
progress-color=over #cba6f7c0
border-radius=15
icons=0
anchor=bottom-center
default-timeout=12000
ignore-timeout=1
font=monospace 14
[urgency=high]
border-color=#f38ba8
default-timeout=0

[summary~=summary]
default-timeout=24000
border-color=#cba6f7

# bin/color-picker (last color picked is hardcoded in config)
[summary=hyprpicker]
border-color=#a69259

# .config/hypr/hyprland.conf && bin/workspaces
[summary=volume]
width=210
text-alignment=center
[summary=mic]
width=210
text-alignment=center
[summary=brightness]
width=210
text-alignment=center
[summary=workspaces]
width=210
[summary="idle inhibitor"]
width=210

# bin/battery-alert
[summary="battery charged"]
border-color=#a6e3a1
[summary="battery low"]
border-color=#fab387
[summary="battery critical"]
border-color=#f38ba8

# bin/battery-charging
[summary="charging"]
border-color=#a6e3a1
[summary="discharging"]
border-color=#a6e3a1
